define inline_javascript reset_ssd_inline_javascript
	set description "Executes JavaScript"
	___run__
	vars.ssd = vars.ssd_start;
	vars.ssd_current = vars.ssd;
	vars.ssd_next = vars.ssd;
	__end__
	set _prepare ""

define inline_javascript staircase_tracking_inline_javascript
	set description "Executes JavaScript"
	___run__
	if (vars.is_stop_trial === 1) {
	    if (vars.stop_responded === 0) {
	        vars.ssd = vars.ssd + vars.ssd_step;
	        vars.inhibition_success = 1;
	    } else {
	        vars.ssd = vars.ssd - vars.ssd_step;
	        vars.inhibition_success = 0;
	    }
	
	    if (vars.ssd < vars.ssd_min) {
	        vars.ssd = vars.ssd_min;
	    }
	
	    if (vars.ssd > vars.ssd_max) {
	        vars.ssd = vars.ssd_max;
	    }
	} else {
	    vars.inhibition_success = "N/A";
	}
	
	vars.ssd_next = vars.ssd;
	__end__
	set _prepare ""

define inline_javascript staircase_tracking_training_inline_javascript
	set description "Executes JavaScript"
	___run__
	if (vars.is_stop_trial === 1) {
	    if (vars.stop_responded === 0) {
	        vars.ssd = vars.ssd + vars.ssd_step;
	        vars.inhibition_success = 1;
	    } else {
	        vars.ssd = vars.ssd - vars.ssd_step;
	        vars.inhibition_success = 0;
	    }
	
	    if (vars.ssd < vars.ssd_min) {
	        vars.ssd = vars.ssd_min;
	    }
	
	    if (vars.ssd > vars.ssd_max) {
	        vars.ssd = vars.ssd_max;
	    }
	} else {
	    vars.inhibition_success = "N/A";
	}
	
	vars.ssd_next = vars.ssd;
	__end__
	set _prepare ""

define sketchpad stop_signal
	set foreground black
	set duration 0
	set description "Displays stimuli"
	set background white
	draw arrow arrow_body_length=0.8 arrow_body_width=0.5 arrow_head_width=30 color=red fill=1 penwidth=1 show_if="[target] = 'right'" x1=-64 x2=64 y1=0 y2=0 z_index=0
	draw arrow arrow_body_length=0.8 arrow_body_width=0.5 arrow_head_width=30 color=red fill=1 penwidth=1 show_if="[target] = 'left'" x1=64 x2=-64 y1=0 y2=0 z_index=0

define sketchpad stop_signal_training
	set foreground black
	set duration 0
	set description "Displays stimuli"
	set background white
	draw arrow arrow_body_length=0.8 arrow_body_width=0.5 arrow_head_width=30 color=red fill=1 penwidth=1 show_if="[target] = 'right'" x1=-64 x2=64 y1=0 y2=0 z_index=0
	draw arrow arrow_body_length=0.8 arrow_body_width=0.5 arrow_head_width=30 color=red fill=1 penwidth=1 show_if="[target] = 'left'" x1=64 x2=-64 y1=0 y2=0 z_index=0

define sketchpad sync_sketchpad
	set foreground white
	set duration 0
	set description "Displays stimuli"
	set background white
	draw textline center=1 color=white font_bold=no font_family=monospace font_italic=no font_size=64 html=yes show_if=always text="[target]" x=0 y=0 z_index=0

define sketchpad sync_training_sketchpad
	set duration 0
	set description "Displays stimuli"

define sketchpad target
	set foreground black
	set duration 0
	set description "Displays stimuli"
	set background white
	draw arrow arrow_body_length=0.8 arrow_body_width=0.5 arrow_head_width=30 color=black fill=1 penwidth=1 show_if="[target] = 'right'" x1=-64 x2=64 y1=0 y2=0 z_index=0
	draw arrow arrow_body_length=0.8 arrow_body_width=0.5 arrow_head_width=30 color=black fill=1 penwidth=1 show_if="[target] = 'left'" x1=64 x2=-64 y1=0 y2=0 z_index=0

define sketchpad target_training_sketchpad
	set foreground black
	set duration 0
	set description "Displays stimuli"
	set background white
	draw arrow arrow_body_length=0.8 arrow_body_width=0.5 arrow_head_width=30 color=black fill=1 penwidth=1 show_if="[target] = 'right'" x1=-64 x2=64 y1=0 y2=0 z_index=0
	draw arrow arrow_body_length=0.8 arrow_body_width=0.5 arrow_head_width=30 color=black fill=1 penwidth=1 show_if="[target] = 'left'" x1=64 x2=-64 y1=0 y2=0 z_index=0

define sequence task
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run initiation_inline_javascript True
	run config_viewport_inline_javascript True
	run custom_identification_page_inline_javascript True
	run Training_Instructions True
	run transition_time_sketchpad True
	run training_loop True
	run End_of_Training True
	run pause_transition True
	run reset_ssd_inline_javascript True
	run block_loop True
	run End_of_Task True

define loop training_loop
	set source_file ""
	set source table
	set repeat 1
	set order random
	set description "Repeatedly runs another item"
	set cycles 16
	set continuous no
	set break_if_on_first yes
	set break_if False
	setcycle 0 correct_response None
	setcycle 0 target left
	setcycle 1 correct_response None
	setcycle 1 target left
	setcycle 2 correct_response None
	setcycle 2 target right
	setcycle 3 correct_response None
	setcycle 3 target right
	setcycle 4 correct_response left
	setcycle 4 target left
	setcycle 5 correct_response left
	setcycle 5 target left
	setcycle 6 correct_response left
	setcycle 6 target left
	setcycle 7 correct_response left
	setcycle 7 target left
	setcycle 8 correct_response left
	setcycle 8 target left
	setcycle 9 correct_response left
	setcycle 9 target left
	setcycle 10 correct_response right
	setcycle 10 target right
	setcycle 11 correct_response right
	setcycle 11 target right
	setcycle 12 correct_response right
	setcycle 12 target right
	setcycle 13 correct_response right
	setcycle 13 target right
	setcycle 14 correct_response right
	setcycle 14 target right
	setcycle 15 correct_response right
	setcycle 15 target right
	run training_trial_sequence

define sequence training_trial_sequence
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run jitter_training_js True
	run mask_training_sketchpad True
	run target_training_sketchpad True
	run kb1_response_training True
	run stop_signal_training "[correct_response] == \"None\" and [response_kb1_response_training] == \"None\""
	run kb2_response_training "[response_kb1_response_training] == \"None\""
	run compute_training_result_inline_javascript True
	run sync_training_sketchpad True
	run staircase_tracking_training_inline_javascript True
	run new_logger True

define sketchpad transition_time_sketchpad
	set duration 2000
	set description "Displays stimuli"

define sketchpad transition_time_training_sketchpad
	set duration 1500
	set description "Displays stimuli"

define sequence trial_sequence
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run jitter_js True
	run mask_sketchpad True
	run target True
	run kb1_response True
	run stop_signal "[correct_response] == \"None\" and [response_kb1_response] == \"None\""
	run kb2_response "[response_kb1_response] == \"None\""
	run compute_trial_result_inline_javascript True
	run sync_sketchpad True
	run staircase_tracking_inline_javascript True
	run logger True

