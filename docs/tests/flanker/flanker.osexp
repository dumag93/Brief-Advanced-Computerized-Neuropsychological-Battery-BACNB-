define form_text_display End_of_Task
	set timeout infinite
	set spacing 10
	set rows "1;8;1"
	set only_render no
	set ok_text Finalizar
	set margins "40;40;40;40"
	set form_title "<span size=24><b>Teste Concluído</b></span>"
	__form_text__
	<b>Parabéns, você chegou ao fim da tarefa!</b>
	
	Todos os seus dados e tempos de reação foram gravados com sucesso pelo sistema. 
	
	Muito obrigado pela sua atenção, foco e participação.
	
	Clique no botão abaixo para encerrar o aplicativo de testes.
	__end__
	set description "A simple text display form"
	set cols "1;2;1"
	set _theme gray
	widget 0 0 3 1 label text="[form_title]"
	widget 0 1 3 1 label center=no text="[form_text]"
	widget 1 2 1 1 button text="[ok_text]"


define form_text_display End_of_Training
	set timeout infinite
	set spacing 10
	set rows "1;5;1"
	set only_render no
	set ok_text "Iniciar Teste"
	set margins "50;50;50;50"
	set form_title "<span size=24><b>Fim do Treino</b></span>"
	__form_text__
	<b>Você concluiu a fase de adaptação com sucesso!</b>
	
	A fase oficial vai começar agora.
	
	Mantenha o foco no <b>ALVO CENTRAL</b> e responda com precisão, sem sacrificar velocidade.
	
	<b>Ao clicar no botão abaixo, iniciaremos um intervalo de 10 segundos para descansar os olhos.</b> Aproveite este momento para relaxar antes do início do teste principal.
	__end__
	set description "Text display form"
	set cols "1;1;1"
	set _theme gray
	widget 0 0 3 1 label text="[form_title]"
	widget 0 1 3 1 label center=no text="[form_text]"
	widget 1 2 1 1 button text="[ok_text]"


define form_text_display Training_Instructions
	set timeout infinite
	set spacing 10
	set rows "1;7;1"
	set only_render no
	set ok_text "Iniciar Treino"
	set margins "50;50;50;50"
	set form_title "<span size=24><b>FLANKER TASK - Instruções</b></span>"
	__form_text__
	<b>REGRA PRINCIPAL: responda somente ao ALVO CENTRAL.</b>
	
	Uma sequência de sinais aparecerá no centro da tela.
	Os sinais ao redor podem ajudar ou atrapalhar. <b>IGNORE OS FLANKERS</b>.
	
	Use as setas do teclado:
	
	<b>Seta esquerda</b> = alvo central apontando para a esquerda
	
	<b>Seta direita</b> = alvo central apontando para a direita
	
	Responda com <b>RAPIDEZ</b>, mas sem sacrificar a <b>PRECISÃO</b>.
	__end__
	set description "Text display form"
	set cols "1;1;1"
	set _theme gray
	widget 0 0 3 1 label text="[form_title]"
	widget 0 1 3 1 label center=no text="[form_text]"
	widget 1 2 1 1 button text="[ok_text]"


define inline_javascript compute_flanker_result_inline_javascript
	set description "Computes Flanker trial result"
	___run__
	function isNone(v) { return v === undefined || v === null || v === "None" || v === "none" || v === ""; }
	function getVar(name, fallback) { try { return vars[name]; } catch(e) { return fallback; } }
	var resp = getVar("response_flanker_response_keyboard", "None");
	var rt = getVar("response_time_flanker_response_keyboard", "None");
	vars.response = isNone(resp) ? "None" : resp;
	vars.response_time = isNone(rt) ? "None" : Number(rt);
	vars.omission = isNone(resp) ? 1 : 0;
	vars.anticipation = (!isNone(rt) && Number(rt) < 100) ? 1 : 0;
	vars.correct = (!isNone(resp) && resp === vars.correct_response) ? 1 : 0;
	vars.error = (vars.omission === 0 && vars.correct === 0) ? 1 : 0;
	__end__
	set _prepare ""

define inline_javascript config_viewport_inline_javascript
	set description "Viewport and fullscreen helper"
	set _run ""
	___prepare__
	try {
	    var viewport = document.querySelector('meta[name=viewport]');
	    if (!viewport) {
	        viewport = document.createElement('meta');
	        viewport.name = 'viewport';
	        document.head.appendChild(viewport);
	    }
	    viewport.content = 'width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no';
	} catch (e) {}
	function ativarFullScreen() {
	    var elem = document.documentElement;
	    if (elem.requestFullscreen) elem.requestFullscreen();
	    else if (elem.webkitRequestFullscreen) elem.webkitRequestFullscreen();
	    document.removeEventListener('click', ativarFullScreen);
	    document.removeEventListener('touchstart', ativarFullScreen);
	}
	document.addEventListener('click', ativarFullScreen);
	document.addEventListener('touchstart', ativarFullScreen);
	__end__

define inline_javascript custom_identification_page_inline_javascript
	set description "Custom participant identification"
	___run__
	// 1. Cria o contêiner principal ocupando 100% da janela (Manta de Fundo)
	var fullScreenOverlay = document.createElement('div');
	fullScreenOverlay.id = 'custom-ident-overlay';
	fullScreenOverlay.style.position = 'fixed';
	fullScreenOverlay.style.top = '0';
	fullScreenOverlay.style.left = '0';
	fullScreenOverlay.style.width = '100vw';
	fullScreenOverlay.style.height = '100vh';
	fullScreenOverlay.style.backgroundColor = '#000000'; // Fundo preto puro bloqueia qualquer vazamento visual
	fullScreenOverlay.style.zIndex = '99999';
	
	// 2. Cria a caixa do formulário (AUMENTADA)
	var formWrapper = document.createElement('div');
	formWrapper.style.position = 'absolute';
	formWrapper.style.top = '50%';
	formWrapper.style.left = '50%';
	formWrapper.style.transform = 'translate(-50%, -50%)';
	formWrapper.style.textAlign = 'center';
	formWrapper.style.fontFamily = 'Helvetica, Arial, sans-serif';
	formWrapper.style.backgroundColor = '#1a1a1a'; // Caixa escura clínica
	formWrapper.style.padding = '50px 45px'; // Aumentado o espaçamento interno
	formWrapper.style.borderRadius = '14px';
	formWrapper.style.boxShadow = '0 12px 30px rgba(0,0,0,0.8)';
	formWrapper.style.width = '460px'; // Aumentado de 380px para 460px
	
	// 3. Cabeçalho
	var header = document.createElement('h2');
	header.innerText = 'Identificação';
	header.style.color = '#ffffff';
	header.style.margin = '0 0 15px 0';
	header.style.fontSize = '26px';
	formWrapper.appendChild(header);
	
	// 4. Instruções (Texto ajustado para o Protocolo)
	var instructions = document.createElement('p');
	instructions.innerText = 'Por favor, preencha o formulário com seu nome completo antes de iniciar o protocolo:';
	instructions.style.color = '#aaaaaa';
	instructions.style.margin = '0 0 30px 0';
	instructions.style.fontSize = '16px';
	instructions.style.lineHeight = '1.5';
	formWrapper.appendChild(instructions);
	
	// 5. Caixa de digitação do nome (Input Text - AUMENTADA)
	var nameInput = document.createElement('input');
	nameInput.type = 'text';
	nameInput.style.padding = '15px 20px'; // Caixa mais alta e confortável para digitar
	nameInput.style.width = '100%';
	nameInput.style.boxSizing = 'border-box';
	nameInput.style.fontSize = '18px'; // Fonte maior para facilitar a leitura do participante
	nameInput.style.border = '2px solid #333333';
	nameInput.style.borderRadius = '8px';
	nameInput.style.backgroundColor = '#2b2b2b';
	nameInput.style.color = '#ffffff';
	nameInput.style.outline = 'none';
	nameInput.style.marginBottom = '30px';
	nameInput.style.textAlign = 'center';
	formWrapper.appendChild(nameInput);
	
	// Efeitos visuais de foco na caixa de texto
	nameInput.onfocus = function() { nameInput.style.border = '2px solid #4CAF50'; };
	nameInput.onblur = function() { nameInput.style.border = '2px solid #333333'; };
	
	// 6. O Botão Físico "Avançar"
	var submitButton = document.createElement('button');
	submitButton.type = 'button';
	submitButton.innerText = 'Avançar';
	submitButton.style.padding = '14px 0';
	submitButton.style.width = '100%';
	submitButton.style.fontSize = '18px';
	submitButton.style.backgroundColor = '#4CAF50';
	submitButton.style.color = '#ffffff';
	submitButton.style.border = 'none';
	submitButton.style.borderRadius = '8px';
	submitButton.style.cursor = 'pointer';
	submitButton.style.fontWeight = 'bold';
	formWrapper.appendChild(submitButton);
	
	// Monta a estrutura na página web
	fullScreenOverlay.appendChild(formWrapper);
	document.body.appendChild(fullScreenOverlay);
	
	// Foca o cursor automaticamente na caixa de texto
	setTimeout(function() {
	    nameInput.focus();
	}, 150);
	
	// 7. Ação do clique do mouse no botão
	submitButton.onclick = function(e) {
	    if (e) e.preventDefault();
	    
	    var cleanName = nameInput.value.trim();
	    
	    if (cleanName === "") {
	        vars.subject_name = "Participante_Anonimo";
	    } else {
	        vars.subject_name = cleanName;
	    }
	    
	    // Remove toda a manta e o formulário da tela de uma vez só
	    var elementToRemove = document.getElementById('custom-ident-overlay');
	    if (elementToRemove) {
	        document.body.removeChild(elementToRemove);
	    }
	    
	    // Avança o experimento mantendo o canvas do OSWeb intacto nos bastidores
	    if (typeof runner !== 'undefined' && runner.resume) {
	        runner.resume();
	    } else if (typeof osweb !== 'undefined' && osweb.runner && osweb.runner.resume) {
	        osweb.runner.resume();
	    }
	};
	__end__
	set _prepare ""

define sketchpad fixation_sketchpad
	set foreground black
	set duration "[jitter_tempo]"
	set description Fixation
	set background white
	draw textline center=1 color="#000000" font_bold=yes font_family=mono font_italic=no font_size=54 html=yes show_if=True text="+" x=0 y=0 z_index=0

define keyboard_response flanker_response_keyboard
	set timeout "[max_rt]"
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Flanker keyboard response"
	set allowed_responses "left;right"

define sketchpad flanker_stimulus_sketchpad
	set foreground black
	set duration 0
	set description "Flanker stimulus"
	set background white
	draw textline center=1 color="#000000" font_bold=yes font_family=mono font_italic=no font_size=60 html=yes show_if=True text="[stimulus_text]" x=0 y=0 z_index=0

define inline_javascript init_flanker_official_inline_javascript
	set description "Initializes balanced official Flanker plan"
	___run__
	function shuffle(a) {
	    for (var i = a.length - 1; i > 0; i--) {
	        var j = Math.floor(Math.random() * (i + 1));
	        var t = a[i]; a[i] = a[j]; a[j] = t;
	    }
	    return a;
	}
	function add(plan, condition, direction) {
	    var stim = "";
	    if (condition === "congruente" && direction === "left") stim = "<<<<<";
	    if (condition === "congruente" && direction === "right") stim = ">>>>>";
	    if (condition === "incongruente" && direction === "left") stim = ">><>>";
	    if (condition === "incongruente" && direction === "right") stim = "<<><<";
	    if (condition === "neutra" && direction === "left") stim = "--<--";
	    if (condition === "neutra" && direction === "right") stim = "-->--";
	    plan.push({condition:condition, target_direction:direction, stimulus_text:stim, correct_response:direction});
	}
	var plan = [];
	for (var r = 0; r < 24; r++) {
	    add(plan, "congruente", "left"); add(plan, "congruente", "right");
	    add(plan, "incongruente", "left"); add(plan, "incongruente", "right");
	    add(plan, "neutra", "left"); add(plan, "neutra", "right");
	}
	window.bnca_flanker_plan = shuffle(plan);
	window.bnca_flanker_index = 0;
	window.bnca_flanker_phase = "official";
	vars.phase = "official";
	__end__
	set _prepare ""

define inline_javascript init_flanker_training_inline_javascript
	set description "Initializes Flanker training plan"
	___run__
	function shuffle(a) {
	    for (var i = a.length - 1; i > 0; i--) {
	        var j = Math.floor(Math.random() * (i + 1));
	        var t = a[i]; a[i] = a[j]; a[j] = t;
	    }
	    return a;
	}
	function add(plan, condition, direction) {
	    var stim = "";
	    if (condition === "congruente" && direction === "left") stim = "<<<<<";
	    if (condition === "congruente" && direction === "right") stim = ">>>>>";
	    if (condition === "incongruente" && direction === "left") stim = ">><>>";
	    if (condition === "incongruente" && direction === "right") stim = "<<><<";
	    if (condition === "neutra" && direction === "left") stim = "--<--";
	    if (condition === "neutra" && direction === "right") stim = "-->--";
	    plan.push({condition:condition, target_direction:direction, stimulus_text:stim, correct_response:direction});
	}
	var plan = [];
	for (var r = 0; r < 2; r++) {
	    add(plan, "congruente", "left"); add(plan, "congruente", "right");
	    add(plan, "incongruente", "left"); add(plan, "incongruente", "right");
	    add(plan, "neutra", "left"); add(plan, "neutra", "right");
	}
	window.bnca_flanker_plan = shuffle(plan);
	window.bnca_flanker_index = 0;
	window.bnca_flanker_phase = "training";
	vars.task_name = "Flanker";
	vars.phase = "training";
	__end__
	set _prepare ""

define logger logger
	set description "Logs experimental variables"
	set auto_log yes

define loop official_loop
	set source table
	set repeat 144
	set order sequential
	set item trial_sequence
	set description "Repeatedly runs another item"
	set cycles 1
	set continuous no
	set break_if_on_first yes
	set break_if False
	setcycle 0 dummy 1
	run trial_sequence

define sketchpad pause_transition
	set duration 10000
	set description "Displays stimuli"
	draw textline center=1 color=black font_bold=no font_family=mono font_italic=no font_size=22 html=yes show_if=always text="" x=0 y=0 z_index=0
	draw textline center=1 color="#000000" font_bold=no font_family=mono font_italic=no font_size=50 html=yes show_if=True text="Aguarde o Início do Teste!" x=0 y=0 z_index=0

define inline_javascript prepare_flanker_trial_inline_javascript
	set description "Prepares one Flanker trial"
	set _run ""
	___prepare__
	var plan = window.bnca_flanker_plan || [];
	var idx = window.bnca_flanker_index || 0;
	var t = plan[idx] || {condition:"missing", target_direction:"None", stimulus_text:"-----", correct_response:"None"};
	window.bnca_flanker_index = idx + 1;
	vars.task_name = "Flanker";
	vars.phase = window.bnca_flanker_phase || "unknown";
	vars.trial_index = idx + 1;
	vars.condition = t.condition;
	vars.target_direction = t.target_direction;
	vars.stimulus_text = t.stimulus_text;
	vars.correct_response = t.correct_response;
	vars.jitter_tempo = Math.floor(Math.random() * (900 - 400 + 1)) + 400;
	vars.max_rt = 1500;
	__end__

define sequence task
	set flush_keyboard yes
	set description "Main task sequence"
	run config_viewport_inline_javascript True
	run custom_identification_page_inline_javascript True
	run Training_Instructions True
	run transition_time_sketchpad True
	run init_flanker_training_inline_javascript True
	run training_loop True
	run End_of_Training True
	run pause_transition True
	run init_flanker_official_inline_javascript True
	run official_loop True
	run End_of_Task True

define loop training_loop
	set source_file ""
	set source table
	set repeat 12
	set order sequential
	set item trial_sequence
	set description "Repeatedly runs another item"
	set cycles 1
	set continuous no
	set break_if_on_first yes
	set break_if False
	setcycle 0 dummy 1
	run trial_sequence

define sketchpad transition_time_sketchpad
	set duration 2000
	set description "Displays stimuli"

define sequence trial_sequence
	set flush_keyboard yes
	set description "One Flanker trial"
	run prepare_flanker_trial_inline_javascript True
	run fixation_sketchpad True
	run flanker_stimulus_sketchpad True
	run flanker_response_keyboard True
	run compute_flanker_result_inline_javascript True
	run logger True

