---
API: 3
Citation: Blackburn & Benton (1957); Woods et al. (2011); Wechsler digit span tradition
Description: Computerized adaptive Digit Span for BACNB
OpenSesame: 4.1.14
Platform: nt
Title: Digit Span (DS)
---
set width 1280
set uniform_coordinates yes
set title "Digit Span (DS)"
set subject_parity even
set subject_nr 0
set start task
set sound_sample_size -16
set sound_freq 48000
set sound_channels 2
set sound_buf_size 1024
set sampler_backend legacy
set round_decimals 2
set mouse_backend osweb
set keyboard_backend osweb
set jatos_uuid "5e4d2589-b8a1-49da-a8fc-1fd437bacabf"
set height 720
set fullscreen no
set form_clicks no
set foreground black
set font_underline no
set font_size 20
set font_italic False
set font_family mono
set font_bold False
set experiment_path "G:\\Meu Drive\\Projeto BRANIAC\\Brief-Advanced-Computerized-Neuropsychological-Battery-BACNB\\Brief-Advanced-Computerized-Neuropsychological-Battery-BACNB-main\\docs\\tests\\digit_span"
set disable_garbage_collection False
set description "BACNB task"
set coordinates uniform
set compensation 0
set color_backend osweb
set clock_backend osweb
set canvas_backend osweb
set bidi no
set background white

define form_text_display End_of_Task
	set timeout infinite
	set spacing 10
	set rows "1;8;1"
	set only_render no
	set ok_text Finalizar
	set margins "40;40;40;40"
	set form_title "<span size=24><b>Teste Concluído</b></span>"
	__form_text__
	<b>Parabéns, você chegou ao fim da tarefa!</b>
	
	Todos os seus dados e tempos de resposta foram gravados com sucesso pelo sistema.
	
	Muito obrigado pela sua atenção, foco e participação.
	
	Clique no botão abaixo para encerrar o aplicativo de testes.
	__end__
	set description "A simple text display form"
	set cols "1;2;1"
	set _theme gray
	widget 0 0 3 1 label text="[form_title]"
	widget 0 1 3 1 label center=no text="[form_text]"
	widget 1 2 1 1 button text="[ok_text]"


define form_text_display End_of_Training
	set timeout infinite
	set spacing 10
	set rows "1;12;1"
	set only_render no
	set ok_text "Iniciar Intervalo"
	set margins "30;40;30;40"
	set form_title "<span size=24><b>Fim do Treino</b></span>"
	__form_text__
	<b>O treino terminou com sucesso!</b>
	
	O teste real começará em breve e as regras são exatamente as mesmas:
	
	• Na <b>ordem direta</b>, repita os dígitos na mesma sequência.
	
	• Na <b>ordem inversa</b>, repita os dígitos de trás para frente.
	
	Antes de começar, você terá <b>10 segundos de intervalo</b> para descansar os olhos. Clique abaixo para iniciar o descanso.
	__end__
	set description "A simple text display form"
	set cols "1;2;1"
	set _theme gray
	widget 0 0 3 1 label text="[form_title]"
	widget 0 1 3 1 label center=no text="[form_text]"
	widget 1 2 1 1 button text="[ok_text]"


define form_text_display Training_Instructions
	set timeout infinite
	set spacing 10
	set rows "1;8;1"
	set only_render no
	set ok_text "Iniciar Treino"
	set margins "40;40;40;40"
	set form_title "<span size=24><b>Instruções Gerais</b></span>"
	__form_text__
	<b>Tarefa de Memória de Dígitos (Digit Span)</b>
	
	Nesta tarefa, números vão aparecer <b>um por vez</b> no centro da tela.
	
	• <b>Ordem direta:</b> digite os números na mesma ordem em que apareceram.
	
	• <b>Ordem inversa:</b> digite os números de trás para frente.
	
	Responda somente quando o campo de resposta aparecer. Começaremos agora com um breve <b>TREINO</b>.
	__end__
	set description "A simple text display form"
	set cols "1;2;1"
	set _theme gray
	widget 0 0 3 1 label text="[form_title]"
	widget 0 1 3 1 label center=no text="[form_text]"
	widget 1 2 1 1 button text="[ok_text]"


define inline_javascript compute_ds_result_inline_javascript
	set description "Scores Digit Span trial and updates adaptive state"
	___run__
	function normDigits(x) { return String(x || "").replace(/[^0-9]/g, ""); }
	var st = window.bnca_ds_state || {phase: vars.phase, done: false};
	var resp = normDigits(vars.response_raw || vars.response);
	var expected = normDigits(vars.expected_response);
	var correct = resp === expected ? 1 : 0;
	vars.response = resp === "" ? "None" : resp;
	vars.response_string = vars.response;
	vars.correct = correct;
	vars.error = correct ? 0 : 1;
	vars.span_credit = correct ? Number(vars.sequence_length) : 0;
	vars.response_time = isNaN(Number(vars.response_time)) ? "None" : Number(vars.response_time);
	vars.trial_total_time_ms = isNaN(Number(vars.trial_total_time_ms)) ? "None" : Number(vars.trial_total_time_ms);
	vars.official_elapsed_ms = isNaN(Number(vars.official_elapsed_ms)) ? "None" : Number(vars.official_elapsed_ms);
	vars.official_total_time_ms = "None";
	if (st.phase === "official" && !st.done) {
	    st.trial_in_length = (st.trial_in_length || 0) + 1;
	    st.successes_in_length = (st.successes_in_length || 0) + correct;
	    if (correct) {
	        if (st.mode === "forward") st.forward_span = Math.max(st.forward_span || 0, Number(vars.sequence_length));
	        if (st.mode === "backward") st.backward_span = Math.max(st.backward_span || 0, Number(vars.sequence_length));
	    }
	    if (st.trial_in_length >= 2) {
	        var advance = st.successes_in_length >= 1;
	        if (advance && st.length < (st.mode === "forward" ? 9 : 8)) {
	            st.length += 1;
	            st.trial_in_length = 0;
	            st.successes_in_length = 0;
	        } else {
	            if (st.mode === "forward") {
	                st.mode = "backward";
	                st.length = 2;
	                st.trial_in_length = 0;
	                st.successes_in_length = 0;
	            } else {
	                st.done = true;
	            }
	        }
	    }
	}
	vars.ds_forward_span = st.forward_span || 0;
	vars.ds_backward_span = st.backward_span || 0;
	vars.ds_span_sum = Number(vars.ds_forward_span) + Number(vars.ds_backward_span);
	vars.ds_done = st.done ? 1 : 0;
	if (st.phase === "official" && st.done && vars.official_elapsed_ms !== "None") {
	    vars.official_total_time_ms = Number(vars.official_elapsed_ms);
	}
	window.bnca_ds_state = st;
	__end__
	set _prepare ""

define inline_javascript config_viewport_inline_javascript
	set description "Executes JavaScript"
	___run__
	// 1. Remove a configuração padrão do navegador móvel
	var oldMeta = document.querySelector('meta[name="viewport"]');
	if (oldMeta) oldMeta.remove();
	
	// 2. Engana o tablet: Força a página a ter exatamente 1280 pixels
	var meta = document.createElement('meta');
	meta.name = 'viewport';
	meta.content = 'width=1280, user-scalable=no';
	document.head.appendChild(meta);
	
	// 3. A Mágica da Elegância: Recria as tarjas pretas no fundo e centraliza
	var estilo = document.createElement('style');
	estilo.innerHTML = `
	    html { 
	        background-color: black !important; 
	        height: 100vh !important; /* Aqui estava 100%. O 100vh garante que ele recalcule o centro ao entrar em tela cheia */
	        width: 100vw !important;
	        display: flex;
	        align-items: center;
	        justify-content: center;
	        margin: 0;
	        padding: 0;
	    }
	    body {
	        background-color: white !important; 
	        width: 1280px !important;
	        height: 720px !important;
	        margin: 0 !important;
	        position: relative !important;
	        overflow: hidden !important;
	        flex-shrink: 0 !important; /* Impede que o navegador esmague a tela branca */
	    }
	`;
	document.head.appendChild(estilo);
	
	// 4. O Gatilho do Full Screen
	function ativarFullScreen() {
	    var elem = document.documentElement;
	    // Verifica se já não está em tela cheia
	    if (!document.fullscreenElement && !document.webkitFullscreenElement) {
	        if (elem.requestFullscreen) {
	            elem.requestFullscreen();
	        } else if (elem.webkitRequestFullscreen) { /* Fallback para tablets antigos */
	            elem.webkitRequestFullscreen();
	        }
	    }
	    // Remove os gatilhos após o primeiro toque para economizar processamento
	    document.removeEventListener('click', ativarFullScreen);
	    document.removeEventListener('touchstart', ativarFullScreen);
	}
	
	// O navegador fica "escutando" o primeiro toque do paciente na tela
	document.addEventListener('click', ativarFullScreen);
	document.addEventListener('touchstart', ativarFullScreen);
	__end__
	set _prepare ""

define inline_javascript custom_identification_page_inline_javascript
	set description "Executes JavaScript"
	___run__
	// 1. Cria o contêiner principal ocupando 100% da janela (Manta de Fundo)
	var fullScreenOverlay = document.createElement('div');
	fullScreenOverlay.id = 'custom-ident-overlay';
	fullScreenOverlay.style.position = 'fixed';
	fullScreenOverlay.style.top = '0';
	fullScreenOverlay.style.left = '0';
	fullScreenOverlay.style.width = '100vw';
	fullScreenOverlay.style.height = '100vh';
	fullScreenOverlay.style.backgroundColor = '#000000'; // Fundo preto puro bloqueia qualquer vazamento visual
	fullScreenOverlay.style.zIndex = '99999';
	
	// 2. Cria a caixa do formulário (AUMENTADA)
	var formWrapper = document.createElement('div');
	formWrapper.style.position = 'absolute';
	formWrapper.style.top = '50%';
	formWrapper.style.left = '50%';
	formWrapper.style.transform = 'translate(-50%, -50%)';
	formWrapper.style.textAlign = 'center';
	formWrapper.style.fontFamily = 'Helvetica, Arial, sans-serif';
	formWrapper.style.backgroundColor = '#1a1a1a'; // Caixa escura clínica
	formWrapper.style.padding = '50px 45px'; // Aumentado o espaçamento interno
	formWrapper.style.borderRadius = '14px';
	formWrapper.style.boxShadow = '0 12px 30px rgba(0,0,0,0.8)';
	formWrapper.style.width = '460px'; // Aumentado de 380px para 460px
	
	// 3. Cabeçalho
	var header = document.createElement('h2');
	header.innerText = 'Identificação';
	header.style.color = '#ffffff';
	header.style.margin = '0 0 15px 0';
	header.style.fontSize = '26px';
	formWrapper.appendChild(header);
	
	// 4. Instruções (Texto ajustado para o Protocolo)
	var instructions = document.createElement('p');
	instructions.innerText = 'Por favor, preencha o formulário com seu nome completo antes de iniciar o protocolo:';
	instructions.style.color = '#aaaaaa';
	instructions.style.margin = '0 0 30px 0';
	instructions.style.fontSize = '16px';
	instructions.style.lineHeight = '1.5';
	formWrapper.appendChild(instructions);
	
	// 5. Caixa de digitação do nome (Input Text - AUMENTADA)
	var nameInput = document.createElement('input');
	nameInput.type = 'text';
	nameInput.style.padding = '15px 20px'; // Caixa mais alta e confortável para digitar
	nameInput.style.width = '100%';
	nameInput.style.boxSizing = 'border-box';
	nameInput.style.fontSize = '18px'; // Fonte maior para facilitar a leitura do participante
	nameInput.style.border = '2px solid #333333';
	nameInput.style.borderRadius = '8px';
	nameInput.style.backgroundColor = '#2b2b2b';
	nameInput.style.color = '#ffffff';
	nameInput.style.outline = 'none';
	nameInput.style.marginBottom = '30px';
	nameInput.style.textAlign = 'center';
	formWrapper.appendChild(nameInput);
	
	// Efeitos visuais de foco na caixa de texto
	nameInput.onfocus = function() { nameInput.style.border = '2px solid #4CAF50'; };
	nameInput.onblur = function() { nameInput.style.border = '2px solid #333333'; };
	
	// 6. O Botão Físico "Avançar"
	var submitButton = document.createElement('button');
	submitButton.type = 'button';
	submitButton.innerText = 'Avançar';
	submitButton.style.padding = '14px 0';
	submitButton.style.width = '100%';
	submitButton.style.fontSize = '18px';
	submitButton.style.backgroundColor = '#4CAF50';
	submitButton.style.color = '#ffffff';
	submitButton.style.border = 'none';
	submitButton.style.borderRadius = '8px';
	submitButton.style.cursor = 'pointer';
	submitButton.style.fontWeight = 'bold';
	formWrapper.appendChild(submitButton);
	
	// Monta a estrutura na página web
	fullScreenOverlay.appendChild(formWrapper);
	document.body.appendChild(fullScreenOverlay);
	
	// Foca o cursor automaticamente na caixa de texto
	setTimeout(function() {
	    nameInput.focus();
	}, 150);
	
	// 7. Ação do clique do mouse no botão
	submitButton.onclick = function(e) {
	    if (e) e.preventDefault();
	    
	    var cleanName = nameInput.value.trim();
	    
	    if (cleanName === "") {
	        vars.subject_name = "Participante_Anonimo";
	    } else {
	        vars.subject_name = cleanName;
	    }
	    
	    // Remove toda a manta e o formulário da tela de uma vez só
	    var elementToRemove = document.getElementById('custom-ident-overlay');
	    if (elementToRemove) {
	        document.body.removeChild(elementToRemove);
	    }
	    
	    // Avança o experimento mantendo o canvas do OSWeb intacto nos bastidores
	    if (typeof runner !== 'undefined' && runner.resume) {
	        runner.resume();
	    } else if (typeof osweb !== 'undefined' && osweb.runner && osweb.runner.resume) {
	        osweb.runner.resume();
	    }
	};
	__end__
	set _prepare ""

define inline_html digit_span_trial_inline_html
	set margins "0;0;0;0"
	__html__
	<style>
	  #ds-root {
	    width: 1280px;
	    height: 720px;
	    margin: 0;
	    padding: 0;
	    position: relative;
	    overflow: hidden;
	    background: #ffffff;
	    color: #000000;
	    font-family: mono, "DejaVu Sans Mono", "Liberation Mono", Consolas, "Courier New", monospace !important;
	    text-align: center;
	  }
	  #ds-status, #ds-main, #ds-prompt, #ds-input, #ds-submit {
	    font-family: mono, "DejaVu Sans Mono", "Liberation Mono", Consolas, "Courier New", monospace !important;
	  }
	  #ds-status {
	    position: absolute;
	    top: 82px;
	    left: 0;
	    width: 100%;
	    font-size: 26px;
	    font-weight: normal;
	    line-height: 1.2;
	  }
	  #ds-main {
	    position: absolute;
	    left: 50%;
	    top: 50%;
	    transform: translate(-50%, -50%);
	    width: 260px;
	    height: 220px;
	    line-height: 220px;
	    font-size: 150px;
	    font-weight: normal;
	    color: #000000;
	  }
	  #ds-response-panel {
	    display: none;
	    position: absolute;
	    left: 50%;
	    top: 50%;
	    transform: translate(-50%, -50%);
	    width: 640px;
	    text-align: center;
	  }
	  #ds-prompt {
	    font-size: 26px;
	    line-height: 1.45;
	    margin-bottom: 24px;
	  }
	  #ds-input {
	    font-family: mono, "DejaVu Sans Mono", "Liberation Mono", Consolas, "Courier New", monospace !important;
	    font-size: 36px;
	    width: 460px;
	    padding: 12px 14px;
	    border: 2px solid #222222;
	    border-radius: 4px;
	    text-align: center;
	    outline: none;
	    background: #ffffff;
	    color: #111111;
	  }
	  #ds-submit {
	    margin-top: 26px;
	    font-family: mono, "DejaVu Sans Mono", "Liberation Mono", Consolas, "Courier New", monospace !important;
	    font-size: 24px;
	    padding: 12px 34px;
	    border: 2px solid #222222;
	    border-radius: 4px;
	    background: #ffffff;
	    color: #111111;
	    cursor: pointer;
	  }
	  #ds-submit:disabled {
	    opacity: 0.35;
	    cursor: default;
	  }
	</style>
	<div id="ds-root">
	  <div id="ds-status"></div>
	  <div id="ds-main">+</div>
	  <div id="ds-response-panel">
	    <div id="ds-prompt"></div>
	    <input id="ds-input" name="response_raw" required autocomplete="off" inputmode="numeric" pattern="[0-9]*">
	    <input id="ds-rt" name="response_time" type="hidden" value="">
	    <input id="ds-trial-total-time" name="trial_total_time_ms" type="hidden" value="">
	    <input id="ds-official-elapsed" name="official_elapsed_ms" type="hidden" value="">
	    <input id="ds-official-total" name="official_total_time_ms" type="hidden" value="">
	    <input id="ds-response" name="response" type="hidden" value="">
	    <div><input id="ds-submit" type="submit" value="Continuar" disabled></div>
	  </div>
	</div>
	<script>
	(function() {
	  function safeVar(name, fallback) {
	    try {
	      if (typeof vars !== "undefined" && vars[name] !== undefined && vars[name] !== null) {
	        return vars[name];
	      }
	    } catch (e) {}
	    return fallback;
	  }
	  var seq = String(safeVar("sequence", "[sequence]") || "").replace(/[^0-9]/g, "").split("");
	  var mode = String(safeVar("recall_order", "[recall_order]") || "forward");
	  var phase = String(safeVar("phase", "[phase]") || "");
	  var main = document.getElementById("ds-main");
	  var status = document.getElementById("ds-status");
	  var panel = document.getElementById("ds-response-panel");
	  var prompt = document.getElementById("ds-prompt");
	  var input = document.getElementById("ds-input");
	  var rt = document.getElementById("ds-rt");
	  var trialTotalTime = document.getElementById("ds-trial-total-time");
	  var officialElapsed = document.getElementById("ds-official-elapsed");
	  var officialTotal = document.getElementById("ds-official-total");
	  var response = document.getElementById("ds-response");
	  var submit = document.getElementById("ds-submit");
	  var idx = -1;
	  var trialStart = 0;
	  var responseStart = 0;
	  status.innerText = mode === "backward" ? "Ordem inversa" : "Ordem direta";
	  function showBlankThenNext() {
	    main.innerText = "";
	    setTimeout(showNextDigit, 500);
	  }
	  function showNextDigit() {
	    idx += 1;
	    if (idx < seq.length) {
	      if (idx === 0) {
	        trialStart = Date.now();
	        if (phase === "official" && !window.bnca_ds_official_start_time) {
	          window.bnca_ds_official_start_time = trialStart;
	        }
	      }
	      panel.style.display = "none";
	      main.style.display = "block";
	      main.innerText = seq[idx];
	      setTimeout(showBlankThenNext, 1000);
	    } else {
	      main.style.display = "none";
	      prompt.innerText = mode === "backward" ? "Digite a sequência na ordem inversa." : "Digite a sequência na mesma ordem.";
	      panel.style.display = "block";
	      submit.disabled = true;
	      responseStart = Date.now();
	      setTimeout(function(){ input.focus(); }, 50);
	    }
	  }
	  function commitResponseTiming() {
	    var now = Date.now();
	    response.value = input.value;
	    rt.value = String(now - responseStart);
	    trialTotalTime.value = trialStart ? String(now - trialStart) : "None";
	    if (phase === "official" && window.bnca_ds_official_start_time) {
	      officialElapsed.value = String(now - window.bnca_ds_official_start_time);
	    } else {
	      officialElapsed.value = "None";
	    }
	    officialTotal.value = "None";
	  }
	  input.addEventListener("input", function() {
	    input.value = input.value.replace(/[^0-9]/g, "");
	    submit.disabled = input.value.length === 0;
	  });
	  input.addEventListener("keydown", function(ev) {
	    if (ev.key === "Enter" && input.value.length > 0) {
	      ev.preventDefault();
	      commitResponseTiming();
	      submit.click();
	    }
	  });
	  submit.addEventListener("click", function(ev) {
	    if (input.value.length === 0) {
	      ev.preventDefault();
	      return false;
	    }
	    commitResponseTiming();
	  });
	  setTimeout(showNextDigit, 700);
	})();
	</script>
	__end__
	set description "Blocking Digit Span presentation and recall"
	set _theme gray

define inline_html ds_order_transition_inline_html
	set margins "0;0;0;0"
	__html__
	<style>
	  #ds-transition-root {
	    width: 1280px;
	    height: 720px;
	    margin: 0;
	    padding: 0;
	    position: relative;
	    overflow: hidden;
	    background: #ffffff;
	    color: #000000;
	    font-family: mono, "DejaVu Sans Mono", "Liberation Mono", Consolas, "Courier New", monospace !important;
	    text-align: center;
	  }
	  #ds-transition-card {
	    position: absolute;
	    left: 50%;
	    top: 50%;
	    transform: translate(-50%, -50%);
	    width: 860px;
	  }
	  #ds-transition-title {
	    font-size: 54px;
	    line-height: 1.2;
	    font-weight: normal;
	    margin-bottom: 28px;
	  }
	  #ds-transition-subtitle {
	    font-size: 26px;
	    line-height: 1.45;
	    margin-bottom: 38px;
	  }
	  #ds-transition-submit {
	    font-family: mono, "DejaVu Sans Mono", "Liberation Mono", Consolas, "Courier New", monospace !important;
	    font-size: 24px;
	    padding: 12px 34px;
	    border: 2px solid #222222;
	    border-radius: 4px;
	    background: #ffffff;
	    color: #111111;
	    cursor: pointer;
	  }
	</style>
	<div id="ds-transition-root">
	  <div id="ds-transition-card">
	    <div id="ds-transition-title">[ds_order_transition_text]</div>
	    <div id="ds-transition-subtitle">[ds_order_transition_subtext]</div>
	    <input id="ds-transition-submit" type="submit" value="Continuar">
	  </div>
	</div>
	__end__
	set description "Transition screen shown at the start of each Digit Span recall order"
	set _theme gray

define inline_javascript init_ds_official_inline_javascript
	set description "Initializes Digit Span official phase"
	___run__
	vars.task_name = "Digit Span";
	vars.phase = "official";
	vars.ds_done = 0;
	vars.ds_forward_span = 0;
	vars.ds_backward_span = 0;
	window.bnca_ds_state = {
	    phase: "official",
	    mode: "forward",
	    length: 2,
	    trial_in_length: 0,
	    successes_in_length: 0,
	    forward_span: 0,
	    backward_span: 0,
	    trial_index: 0,
	    last_recall_order: "",
	    done: false
	};
	window.bnca_ds_official_start_time = null;
	vars.trial_total_time_ms = "None";
	vars.official_elapsed_ms = "None";
	vars.official_total_time_ms = "None";
	__end__
	set _prepare ""

define inline_javascript init_ds_training_inline_javascript
	set description "Initializes Digit Span training"
	___run__
	vars.task_name = "Digit Span";
	vars.phase = "training";
	vars.ds_done = 0;
	vars.ds_forward_span = 0;
	vars.ds_backward_span = 0;
	window.bnca_ds_state = {
	    phase: "training",
	    training_plan: [
	        {mode: "forward", length: 2},
	        {mode: "forward", length: 3},
	        {mode: "backward", length: 2},
	        {mode: "backward", length: 3}
	    ],
	    trial_index: 0,
	    last_recall_order: "",
	    done: false
	};
	vars.trial_total_time_ms = "None";
	vars.official_elapsed_ms = "None";
	vars.official_total_time_ms = "None";
	__end__
	set _prepare ""

define logger logger
	set description "Logs all variables"
	set auto_log yes

define loop official_loop
	set source_file ""
	set source table
	set repeat 34
	set order sequential
	set item trial_sequence
	set description "Repeatedly runs another item"
	set cycles 1
	set continuous no
	set break_if_on_first yes
	set break_if "[ds_done] == 1"
	setcycle 0 dummy 1
	run trial_sequence

define sketchpad pause_transition
	set duration 10000
	set description "Displays stimuli"
	set background white
	draw textline center=1 color="#000000" font_bold=no font_family=mono font_italic=no font_size=50 html=yes show_if=True text="Aguarde o Início do Teste!" x=0 y=0 z_index=0

define inline_javascript prepare_ds_trial_inline_javascript
	set description "Prepares one Digit Span trial"
	___run__
	function sampleDigits(n) {
	    var out = [];
	    while (out.length < n) {
	        var d = String(Math.floor(Math.random() * 9) + 1);
	        if (out.length === 0 || out[out.length - 1] !== d) out.push(d);
	    }
	    return out;
	}
	var st = window.bnca_ds_state || {phase: "official", mode: "forward", length: 2, trial_index: 0, done: false};
	st.trial_index += 1;
	var mode = st.mode || "forward";
	var len = st.length || 2;
	if (st.phase === "training") {
	    var plan = st.training_plan[Math.min(st.trial_index - 1, st.training_plan.length - 1)];
	    mode = plan.mode;
	    len = plan.length;
	}
	var previousMode = st.last_recall_order || "";
	var showTransition = (previousMode === "" || previousMode !== mode) ? 1 : 0;
	st.last_recall_order = mode;
	vars.ds_show_order_transition = showTransition;
	vars.ds_order_transition_text = mode === "backward" ? "Digite a Ordem Inversa" : "Digite a Ordem Direta";
	vars.ds_order_transition_subtext = mode === "backward" ? "A partir de agora, digite os números de trás para frente." : "A partir de agora, digite os números na mesma ordem em que aparecerem.";
	var seq = sampleDigits(len);
	var expected = mode === "backward" ? seq.slice().reverse().join("") : seq.join("");
	vars.task_name = "Digit Span";
	vars.phase = st.phase;
	vars.trial_index = st.trial_index;
	vars.condition = mode;
	vars.recall_order = mode;
	vars.sequence_length = len;
	vars.sequence = seq.join("");
	vars.expected_response = expected;
	vars.response = "None";
	vars.response_raw = "";
	vars.response_string = "None";
	vars.response_time = "None";
	vars.trial_total_time_ms = "None";
	vars.official_elapsed_ms = "None";
	vars.official_total_time_ms = "None";
	vars.correct = 0;
	vars.error = 0;
	vars.span_credit = 0;
	vars.ds_forward_span = st.forward_span || 0;
	vars.ds_backward_span = st.backward_span || 0;
	vars.ds_done = st.done ? 1 : 0;
	__end__
	set _prepare ""

define sequence task
	set flush_keyboard no
	set description "Main task sequence"
	run config_viewport_inline_javascript True
	run custom_identification_page_inline_javascript True
	run Training_Instructions True
	run init_ds_training_inline_javascript True
	run training_loop True
	run End_of_Training True
	run pause_transition True
	run init_ds_official_inline_javascript True
	run official_loop True
	run End_of_Task True

define loop training_loop
	set source_file ""
	set source table
	set repeat 4
	set order sequential
	set item trial_sequence
	set description "Repeatedly runs another item"
	set cycles 1
	set continuous no
	set break_if_on_first yes
	set break_if False
	setcycle 0 dummy 1
	run trial_sequence

define sequence trial_sequence
	set flush_keyboard no
	set description "One Digit Span trial"
	run prepare_ds_trial_inline_javascript True
	run ds_order_transition_inline_html "[ds_show_order_transition] == 1"
	run digit_span_trial_inline_html True
	run compute_ds_result_inline_javascript True
	run logger True

